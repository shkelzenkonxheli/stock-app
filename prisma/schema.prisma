// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id        Int      @id @default(autoincrement())
  name      String
  brand     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variants Variant[]

  @@index([createdAt])
  @@index([name])
  @@index([brand])
}

model Variant {
  id        Int      @id @default(autoincrement())
  productId Int
  size      String
  color     String
  sku       String?  @unique
  barcode   String?  @unique
  imagePath String?
  stock     Int      @default(0)
  price     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  orders  Order[]
  items   OrderItem[]
  stockMovements StockMovement[]

  @@index([productId])
  @@index([productId, size])
  @@index([productId, color])
  @@index([stock])
  @@index([createdAt])
}

model StockMovement {
  id        Int               @id @default(autoincrement())
  variantId  Int
  quantity  Int
  reason    StockMovementReason
  createdAt DateTime          @default(now())

  variant Variant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId])
  @@index([createdAt])
  @@index([reason])
}

model Order {
  id           Int         @id @default(autoincrement())
  customerName String
  phone        String
  instagram    String?
  source       OrderSource @default(INSTAGRAM)
  quantity     Int?
  notes        String?
  status       OrderStatus @default(NEW)
  variantId    Int?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  variant Variant?    @relation(fields: [variantId], references: [id])
  items   OrderItem[]

  @@index([createdAt])
  @@index([status])
  @@index([source])
  @@index([variantId])
}

model OrderItem {
  id        Int      @id @default(autoincrement())
  orderId    Int
  variantId Int
  quantity  Int
  createdAt DateTime @default(now())

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant Variant @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([variantId])
}

model User {
  id           Int        @id @default(autoincrement())
  name         String
  email        String     @unique
  passwordHash String
  role         UserRole
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  sessions Session[]
}

model Session {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

enum OrderStatus {
  NEW
  READY
  DONE
  CANCELED
}

enum OrderSource {
  INSTAGRAM
  STORE
  WHOLESALE
}

enum UserRole {
  SUPER_ADMIN
  SELLER
  WAREHOUSE
}

enum StockMovementReason {
  INCOMING_STOCK
  CUSTOMER_RETURN
}
